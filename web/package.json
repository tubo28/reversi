{
  "name": "reversi-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "cargo build --release --lib --target wasm32-unknown-unknown --manifest-path ../Cargo.toml && cp ../target/wasm32-unknown-unknown/release/reversi.wasm public/reversi.wasm",
    "predev": "npm run wasm",
    "dev": "vite",
    "prebuild": "npm run wasm",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
