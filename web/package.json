{
  "name": "reversi-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "cargo build --release --lib --target wasm32-unknown-unknown --manifest-path ../Cargo.toml && cp ../target/wasm32-unknown-unknown/release/reversi.wasm public/reversi.wasm",
    "predev": "npm run wasm",
    "dev": "vite",
    "prebuild": "npm run wasm",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^7.1.0"
  }
}
